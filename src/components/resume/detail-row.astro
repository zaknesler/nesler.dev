---
import DataItem from "./data-item.astro";

type Props = {
  title: string;
  subheadings: string[];
  dataItems: string[];
};

const { title, subheadings, dataItems } = Astro.props as Props;
---

<div class="flex flex-col gap-4">
  <div class="flex flex-row flex-wrap items-start justify-between gap-3">
    <div class="flex flex-col gap-1">
      <div class="font-medium leading-5 text-black dark:text-olive-100">
        {title}
      </div>

      <div class="flex flex-col gap-0.5">
        {
          subheadings.map((text) => (
            <div class="text-sm/4 text-olive-500 dark:text-olive-400">
              {text}
            </div>
          ))
        }
      </div>
    </div>

    <div class="shrink-0 flex gap-2 items-center text-xs font-medium text-olive-700 dark:text-olive-200">
      {dataItems.map((item) => <DataItem>{item}</DataItem>)}
    </div>
  </div>

  <div class="flex flex-col gap-4">
    <slot />
  </div>
</div>
