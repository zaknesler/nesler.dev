---
import dayjs from "dayjs";
import GitHubIcon from "@/assets/github.svg";
import LinkedInIcon from "@/assets/linkedin.svg";
import ListGroup from "@/components/list-group.astro";
import BaseLayout from "@/layouts/base.astro";
import data from "../../public/resume.json";
import DetailRow from "@/components/resume/detail-row.astro";
import SectionHeader from "@/components/resume/section-header.astro";
import Title from "@/components/title.astro";

const socialLinks = [
  { label: "GitHub", icon: GitHubIcon, url: data.urls.github },
  { label: "LinkedIn", icon: LinkedInIcon, url: data.urls.linkedin },
] as const;
---

<BaseLayout title="Résumé" description="Résumé of full-stack engineer Zak Nesler.">
  <a href="/" class="self-start inline-flex items-center gap-2 hover:text-black dark:hover:text-olive-100 hover:underline print:hidden">
    <svg
      class="w-4 h-4 text-olive-500 dark:text-olive-400"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15m0 0l6.75 6.75M4.5 12l6.75-6.75"></path>
    </svg>
    Home
  </a>

  <section class="flex flex-col gap-4 items-center justify-between text-center sm:flex-row sm:text-left">
	  <Title />

    <div class="flex flex-col gap-2 font-medium sm:text-right">
      <div class="flex items-center gap-4">
        {
          socialLinks.map(({ label, icon, url }) => (
            <a href={url} target="_blank" rel="noopener noreferrer" title={label}>
              <img src={icon.src} class="w-6 h-6" alt={label} />
            </a>
          ))
        }

        <span>@zaknesler</span>
      </div>

      <div class="text-olive-500 text-sm" set:html={data.email} />
    </div>
  </section>

  <section class="flex flex-col gap-4">
    <SectionHeader title="Professional Qualities" />

    <div>
     	<ListGroup items={data.qualities} />
    </div>
  </section>

  <section class="flex flex-col gap-4">
    <SectionHeader title="Skills" right="Ready and willing to learn anything!" />

    <div class="flex flex-col gap-4">
      {
        Object.entries(data.skills).map(([name, items]) => (
          <div class="grid grid-cols-1 gap-4 md:grid-cols-5">
            <div class="-mb-3 font-medium text-black dark:text-olive-100 md:mb-0">
              {name.charAt(0).toUpperCase() + name.slice(1)}
            </div>
            <div class="col-span-4">{items.join(", ")}</div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="flex flex-col gap-4">
    <SectionHeader title="Experience" />

    <div class="flex flex-col gap-8">
      {
        data.experience.map((item) => (
          <DetailRow
            title={item.position}
            subheadings={[item.company, item.location]}
            dataItems={[
              `${dayjs(item.date_start).format("MMM YYYY")} – ${item.date_end ? dayjs(item.date_end).format("MMM YYYY") : "Present"}`,
            ]}
          >
            <ListGroup items={item.description_list} />
          </DetailRow>
        ))
      }
    </div>
  </section>

  <section class="flex flex-col gap-4">
    <SectionHeader title="Education" />

    <div class="flex flex-col gap-8">
      {
        data.education.map((item) => (
          <DetailRow
            title={item.school}
            subheadings={[
              item.location,
              `${item.year_start} – ${item.year_end}`,
            ]}
            dataItems={[
              `GPA: ${item.gpa}`,
              `Major GPA: ${item.gpa_major}`,
            ]}
          >
            <div>{item.description}</div>
            <div class="text-sm flex flex-col gap-2">
              <div class="font-semibold text-black dark:text-olive-100">
                Relevant Courses & Skills
              </div>

              <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 sm:gap-4">
                {item.courses && (
                  <>
                    <ListGroup items={item.courses.slice( 0, item.courses.length / 2 + 1, )} />
                    <ListGroup items={item.courses.slice( item.courses.length / 2 + 1, )} />
                  </>
                )}
              </div>
            </div>
          </DetailRow>
        ))
      }
    </div>
  </section>
</BaseLayout>
