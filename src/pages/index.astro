---
import BaseLayout from "@/layouts/base.astro";
import data from "../../public/resume.json";
import Title from "@/components/title.astro";

const links = [
  { title: "Résumé", path: "/resume" },
  { title: "Gallery", path: data.urls.gallery },
  { title: "GitHub", path: data.urls.github },
  { title: "Last.fm", path: data.urls.lastfm },
] as const;
---

<BaseLayout description="Full-stack engineer and designer based in Philadelphia with a passion for beautiful design and tidy code.">
  <main class="flex items-start gap-16">
    <div class="flex flex-col gap-4 shrink-0">
      <Title />

      <div class="shrink-0 w-24 h-1 bg-linear-to-r from-olive-700 to-olive-500 dark:from-olive-800 dark:to-olive-700" />

      <ul class="flex flex-col gap-2 font-semibold">
        {
          links.map(({ title, path }) => (
            <li>
              <a href={path} class="inline-flex items-center gap-2 hover:text-black dark:hover:text-white hover:underline" target={path.startsWith("/") ? undefined : "_blank"}>
                {title}

                {!path.startsWith("/") && (
                  <svg class="w-4 h-4 text-olive-500 dark:text-olive-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
                  </svg>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </main>
</BaseLayout>
